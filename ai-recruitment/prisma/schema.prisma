// SmartHire AI Recruitment - Prisma Schema

generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                 @id @default(cuid())
  name             String?
  email            String                 @unique
  candidate        Candidate?
  recruiter        Recruiter?
  emailVerified    DateTime?
  password         String?
  image            String?
  role             Role                   @default(CANDIDATE)
  company          Company?               @relation(fields: [companyId], references: [id])
  companyId        String?
  jobs             Job[]
  accounts         Account[]
  sessions         Session[]
  savedJobsList    SavedJob[]
  jobAlertRules    JobAlert[]
  headline         String?
  phone            String?
  location         String?
  school           String?
  graduationYear   String?
  linkedInUrl      String?
  githubUrl        String?
  websiteUrl       String?
  jobAlerts        Boolean                @default(true)
  aiSuggestions    Boolean                @default(false)
  publicProfile    Boolean                @default(true)
  reputationScore  Int                    @default(0)
  technicalScore   Int                    @default(0)
  softScore        Int                    @default(0)
  resumeVersions   ResumeVersion[]
  mockSessions     MockInterviewSession[]
  careerMilestones CareerMilestone[]
  skillGoals       SkillGoal[]
  notifications    Notification[]
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id             String  @id @default(cuid())
  name           String
  logo           String?
  industry       String?
  size           String?
  averageSalaryL Int?
  employeeRating Float?
  users          User[]
  jobs           Job[]
  website        String?
  description    String?  @db.Text
  location       String?
  foundedYear    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
  @@index([industry])
}

// Recruiter profile extending User (users with role = RECRUITER)
model Recruiter {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  title      String?
  department String?
  bio        String?  @db.Text
  avatarUrl  String?
  jobs       Job[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Job {
  id                 String              @id @default(cuid())
  title              String
  description        String              @db.Text
  requirements       String              @db.Text
  location           String
  type               JobType
  status             JobStatus           @default(ACTIVE)
  salary             String?
  salaryMin          Int?
  salaryMax          Int?
  experienceLevel    String?
  experienceMin      Int?
  experienceMax      Int?
  workMode           WorkMode?
  requiredSkills     String[]            @default([])
  postedBy           User                @relation(fields: [userId], references: [id])
  userId             String
  recruiter          Recruiter?          @relation(fields: [recruiterId], references: [id])
  recruiterId        String?
  company            Company             @relation(fields: [companyId], references: [id])
  companyId          String
  applications       Application[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  alerts             JobAlert[]
  savedBy            SavedJob[]
  jobRecommendations JobRecommendation[]
  behaviorEvents     BehaviorEvent[]
  jobSkills          JobSkill[]
  embeddings         JobEmbedding[]
  recommendationScores JobRecommendationScore[]

  @@index([title])
  @@index([location])
  @@index([experienceLevel])
  @@index([experienceMin, experienceMax])
  @@index([createdAt])
  @@index([workMode])
  @@index([type])
  @@index([status, createdAt])
  @@index([companyId])
  @@index([salaryMin])
  @@index([salaryMax])
  @@index([requiredSkills], type: Gin)
  @@index([recruiterId])
}

model Candidate {
  id                  String            @id @default(cuid())
  userId              String?           @unique
  user                User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  email               String            @unique
  phone               String?
  headline            String?
  location            String?
  city                String?
  country             String?
  photoUrl            String?
  avatarUrl           String?   // uploaded profile picture (CDN URL)
  summary             String?           @db.Text
  profileCompleteness Int               @default(0)
  resumeUrl           String?
  skills              String[]          @default([])
  experience          Int?
  aiScore             Float?
  aiSummary           String?           @db.Text
  // Advanced fields
  availability        String?           // IMMEDIATE, 2_WEEKS, 1_MONTH, 3_MONTHS
  workAuthorization   String?           // CITIZEN, PERMANENT_RESIDENT, VISA, OPT
  openToFreelance     Boolean           @default(false)
  internshipInterest  Boolean           @default(false)
  languagesSpoken     String[]          @default([])
  applications        Application[]
  profile             CandidateProfile?
  educations          Education[]
  skillRecords        Skill[]
  experiences         Experience[]
  projects            Project[]
  certifications      Certification[]
  careerPreference    CareerPreference?
  privacy             ProfilePrivacy?
  aiInsights          AIProfileInsights?
  reputation          ReputationMetrics?
  profileVersions     ProfileVersion[]
  connectedAccounts   ConnectedAccount[]
  behaviorEvents      BehaviorEvent[]
  candidateSkills     CandidateSkill[]
  resumeEmbeddings       ResumeEmbedding[]
  analytics              CandidateAnalytics?
  jobRecommendationScores JobRecommendationScore[]
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  @@index([email])
  @@index([userId])
  @@index([skills], type: Gin)
  @@index([profileCompleteness])
}

model Experience {
  id             String    @id @default(cuid())
  candidateId    String
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company        String
  jobTitle       String
  employmentType String?   // FULL_TIME, PART_TIME, CONTRACT, FREELANCE, INTERNSHIP
  location       String?
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean   @default(false)
  description    String?   @db.Text
  achievements   String[]  @default([])
  technologies   String[]  @default([])
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([candidateId])
}

model Project {
  id           String    @id @default(cuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  title        String
  description  String?   @db.Text
  technologies String[]  @default([])
  repoUrl      String?
  demoUrl      String?
  teamRole     String?
  startDate    DateTime?
  endDate      DateTime?
  isCurrent    Boolean   @default(false)
  order        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([candidateId])
}

model Certification {
  id           String    @id @default(cuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name         String
  issuer       String
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?
  credentialUrl String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([candidateId])
}

model CareerPreference {
  id                 String    @id @default(cuid())
  candidateId        String    @unique
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  preferredRoles     String[]  @default([])
  preferredIndustries String[] @default([])
  preferredLocations String[]  @default([])
  workMode           String?   // REMOTE, HYBRID, ONSITE
  salaryMin          Int?
  salaryMax          Int?
  currency           String?   @default("USD")
  openToRelocation   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model ProfilePrivacy {
  id              String    @id @default(cuid())
  candidateId     String    @unique
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  isPublic        Boolean   @default(true)
  visibleToRecruiters Boolean @default(true)
  anonymousMode   Boolean   @default(false)
  hideContactInfo Boolean   @default(false)
  updatedAt       DateTime  @updatedAt
}

model ProfileVersion {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  version     Int
  snapshot    Json      // Full profile JSON snapshot
  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model AIProfileInsights {
  id                     String    @id @default(cuid())
  candidateId            String    @unique
  candidate              Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  extractedSkills        String[]  @default([])
  experienceSummary      String?   @db.Text
  careerLevel            String?   // JUNIOR, MID, SENIOR, LEAD, EXECUTIVE
  roleReadinessScore     Float?
  skillStrengthDistribution Json?  // { "Frontend": 80, "Backend": 60, ... }
  suggestedImprovements  String[]  @default([])
  lastAnalyzedAt         DateTime?
  updatedAt              DateTime  @updatedAt
}

model ReputationMetrics {
  id                     String    @id @default(cuid())
  candidateId            String    @unique
  candidate              Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  interviewPerformance   Float     @default(0)
  recruiterFeedback      Float     @default(0)
  assessmentCompletionRate Float   @default(0)
  responseRate           Float     @default(0)
  overallScore           Float     @default(0)
  updatedAt              DateTime  @updatedAt
}

model Application {
  id                    String                     @id @default(cuid())
  job                   Job                        @relation(fields: [jobId], references: [id])
  jobId                 String
  candidate             Candidate                  @relation(fields: [candidateId], references: [id])
  candidateId           String
  status                ApplicationStatus          @default(APPLIED)
  aiScore               Float?
  aiNotes               String?                    @db.Text
  interviewProbability  Float?                     @default(0)
  applicationHealthScore Float?                    @default(0)
  readinessScore        Float?                     @default(0)
  interview             Interview?
  statusHistory         ApplicationStatusHistory[]
  recruiterActivities   RecruiterActivity[]
  assessments           Assessment[]
  notes                 ApplicationNote[]
  offer                 Offer?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  @@unique([jobId, candidateId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([candidateId, status])
  @@index([candidateId, createdAt])
}

model ApplicationStatusHistory {
  id            String            @id @default(cuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        ApplicationStatus
  updatedBy     String?
  metadata      Json?
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([applicationId, createdAt])
}

model RecruiterActivity {
  id            String                @id @default(cuid())
  applicationId String
  application   Application           @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  activityType  RecruiterActivityType
  metadata      Json?
  createdAt     DateTime              @default(now())

  @@index([applicationId])
  @@index([applicationId, createdAt])
  @@index([activityType])
  @@index([createdAt])
}

model Assessment {
  id            String           @id @default(cuid())
  applicationId String
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  title         String
  type          String
  score         Float?
  maxScore      Float?
  deadline      DateTime?
  status        AssessmentStatus @default(PENDING)
  completedAt   DateTime?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([applicationId])
  @@index([deadline])
  @@index([status])
}

model ApplicationNote {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  content       String      @db.Text
  authorId      String
  authorRole    String      @default("CANDIDATE")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
  @@index([applicationId, createdAt])
}

model Offer {
  id            String      @id @default(cuid())
  applicationId String      @unique
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  salary        Int?
  currency      String?     @default("USD")
  benefits      String[]    @default([])
  startDate     DateTime?
  expiresAt     DateTime?
  status        OfferStatus @default(PENDING)
  metadata      Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([applicationId])
}

model CandidateAnalytics {
  id                String    @id @default(cuid())
  candidateId       String    @unique
  candidate         Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  applicationsSent  Int       @default(0)
  resumeViewed      Int       @default(0)
  shortlistedCount  Int       @default(0)
  interviewCount    Int       @default(0)
  offerCount        Int       @default(0)
  hiredCount        Int       @default(0)
  rejectedCount     Int       @default(0)
  withdrawnCount    Int       @default(0)
  avgHealthScore    Float     @default(0)
  avgResponseTime   Float?
  lastUpdatedAt     DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([candidateId])
}

model SavedJob {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, jobId])
  @@index([userId, createdAt])
  @@index([jobId])
}

model JobAlert {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  location  String?
  createdAt DateTime  @default(now())
  jobId     String?
  job       Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([role])
  @@index([location])
}

model Education {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  school      String
  degree      String
  field       String
  startYear   String
  endYear     String?
  isCurrent   Boolean   @default(false)
  cgpa        String?
  description String?   @db.Text
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId])
}

model Skill {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  level       SkillLevel @default(INTERMEDIATE)
  category    String?    // e.g., "Frontend", "Backend", "DevOps", "Soft Skills"
  isSoftSkill Boolean    @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId])
}

model CandidateSkill {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  normalized  String
  level       Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId])
  @@index([normalized])
  @@unique([candidateId, normalized])
}

model JobSkill {
  id         String   @id @default(cuid())
  jobId       String
  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  normalized  String
  importance  Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([jobId])
  @@index([normalized])
  @@unique([jobId, normalized])
}

enum BehaviorEventType {
  JOB_VIEW
  JOB_CLICK
  JOB_APPLICATION
  JOB_SAVE
  JOB_IGNORE
}

model BehaviorEvent {
  id         String            @id @default(cuid())
  candidateId String
  candidate  Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId      String?
  job        Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  eventType  BehaviorEventType
  metadata   Json?
  createdAt  DateTime          @default(now())

  @@index([candidateId, createdAt])
  @@index([candidateId, eventType])
  @@index([jobId, createdAt])
}

model ResumeEmbedding {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  source      String    @default("RESUME")
  dimensions  Int
  embedding   Float[]
  checksum    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([candidateId, createdAt])
}

model JobEmbedding {
  id         String   @id @default(cuid())
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  source     String   @default("JOB_DESCRIPTION")
  dimensions Int
  embedding  Float[]
  checksum   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([jobId, source])
  @@index([jobId, createdAt])
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum AccountProvider {
  GITHUB
  LINKEDIN
  GOOGLE
  HUBSPOT
  SLACK
  ZOOM
  PORTFOLIO
  WEBSITE
  TWITTER
  KAGGLE
  LEETCODE
}

model ConnectedAccount {
  id             String          @id @default(cuid())
  candidateId    String
  candidate      Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  provider       AccountProvider
  username       String?         // display username / handle
  profileUrl     String          // validated external URL
  isOAuth        Boolean         @default(false)
  accessToken    String?         // encrypted at the application layer
  refreshToken   String?         // encrypted at the application layer
  tokenExpiresAt DateTime?       // when the access token expires
  scopes         String[]        @default([]) // granted OAuth scopes
  metadata       Json?           // provider-specific extra data
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([candidateId, provider])
  @@index([candidateId])
}

model Interview {
  id            String          @id @default(cuid())
  application   Application     @relation(fields: [applicationId], references: [id])
  applicationId String          @unique
  scheduledAt   DateTime
  duration      Int?            // duration in minutes
  meetingUrl    String?
  notes         String?         @db.Text
  type          InterviewType
  aiTranscript  String?         @db.Text
  aiFeedback    String?         @db.Text
  status        InterviewStatus @default(SCHEDULED)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([scheduledAt])
  @@index([status])
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  REMOTE
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  RESUME_VIEWED
  UNDER_REVIEW
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER
  REJECTED
  HIRED
  WITHDRAWN
}

enum RecruiterActivityType {
  RESUME_VIEWED
  PROFILE_VIEWED
  SHORTLISTED
  INTERVIEW_SCHEDULED
  NOTE_ADDED
  ASSESSMENT_SENT
  OFFER_SENT
  REJECTED
}

enum AssessmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum InterviewType {
  AI_SCREENING
  VIDEO
  PHONE
  IN_PERSON
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  WITHDRAWN
}

enum NotificationType {
  APPLICATION_STATUS_CHANGED
  INTERVIEW_SCHEDULED
  INTERVIEW_REMINDER
  OFFER_RECEIVED
  OFFER_ACCEPTED
  OFFER_DECLINED
  JOB_RECOMMENDATION
  PROFILE_VIEWED
  ASSESSMENT_ASSIGNED
  ASSESSMENT_DUE
  MESSAGE_RECEIVED
  SYSTEM
}

// ---- Candidate workspace models ----

model ResumeVersion {
  id          String              @id @default(cuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  roleTarget  String?
  fileUrl     String?
  atsScore    Int?
  status      ResumeVersionStatus @default(DRAFT)
  suggestions ResumeSuggestion[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ResumeSuggestion {
  id              String         @id @default(cuid())
  resumeVersionId String
  resumeVersion   ResumeVersion  @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  type            SuggestionType
  section         String
  title           String
  description     String         @db.Text
  applied         Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

model MockInterviewSession {
  id         String                 @id @default(cuid())
  userId     String
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String?
  type       MockInterviewType      @default(TECHNICAL)
  status     MockInterviewStatus    @default(IN_PROGRESS)
  startedAt  DateTime               @default(now())
  endedAt    DateTime?
  transcript String?                @db.Text
  aiFeedback String?                @db.Text
  messages   MockInterviewMessage[]
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
}

model MockInterviewMessage {
  id        String               @id @default(cuid())
  sessionId String
  session   MockInterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String               @db.Text
  createdAt DateTime             @default(now())
}

model CareerMilestone {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?   @db.Text
  targetDate  DateTime?
  completed   Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SkillGoal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  category     String?
  currentLevel Int      @default(0)
  targetLevel  Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum ResumeVersionStatus {
  DRAFT
  ACTIVE
}

enum SuggestionType {
  CRITICAL
  IMPROVEMENT
  OPTIMIZATION
}

enum MockInterviewType {
  BEHAVIORAL
  TECHNICAL
  SYSTEM_DESIGN
}

enum MockInterviewStatus {
  IN_PROGRESS
  COMPLETED
}

enum MessageRole {
  USER
  ASSISTANT
}

// ---- Candidate Intelligence Pipeline Models ----

enum ProcessingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model CandidateProfile {
  id               String           @id @default(cuid())
  candidateId      String           @unique
  candidate        Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  version          Int              @default(1)
  readinessScore   Float            @default(0)
  processingStatus ProcessingStatus @default(PENDING)

  resumeRaw          ResumeRaw?
  resumeStructured   ResumeStructured?
  atsScore           ATSScore?
  skillGap           SkillGap?
  careerPath         CareerPath?
  reputationScore    ReputationScore?
  jobRecommendations JobRecommendation[]
  aiLogs             AIExplainabilityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResumeRaw {
  id            String           @id @default(cuid())
  profileId     String           @unique
  profile       CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  fileUrl       String
  extractedText String           @db.Text
  uploadedAt    DateTime         @default(now())
}

model ResumeStructured {
  id         String           @id @default(cuid())
  profileId  String           @unique
  profile    CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skills     String[]
  experience Json
  education  Json
  updatedAt  DateTime         @updatedAt
}

model ATSScore {
  id              String           @id @default(cuid())
  profileId       String           @unique
  profile         CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  overallScore    Float
  roleBasedScores Json
  updatedAt       DateTime         @updatedAt
}

model SkillGap {
  id            String           @id @default(cuid())
  profileId     String           @unique
  profile       CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  missingSkills String[]
  learningPath  Json
  updatedAt     DateTime         @updatedAt
}

model CareerPath {
  id               String           @id @default(cuid())
  profileId        String           @unique
  profile          CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  suggestedRoles   String[]
  readinessPercent Float
  updatedAt        DateTime         @updatedAt
}

model JobRecommendation {
  id              String           @id @default(cuid())
  profileId       String
  profile         CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  jobId           String
  job             Job              @relation(fields: [jobId], references: [id])
  matchScore      Float
  skillMatch      Float?
  experienceMatch Float?
  locationMatch   Float?
  semanticScore   Float?
  readinessScore  Float?
  missingSkills   String[]
  reasons         String[]
  createdAt       DateTime         @default(now())

  @@unique([profileId, jobId])
  @@index([profileId, matchScore(sort: Desc)])
}

// Precomputed recommendation scores keyed by candidateId (not profileId).
// Updated asynchronously by recommendationWorker. Used by the fast API path.
model JobRecommendationScore {
  id                   String    @id @default(cuid())
  candidateId          String
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId                String
  job                  Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillMatchScore      Float     @default(0)
  experienceMatchScore Float     @default(0)
  locationMatchScore   Float     @default(0)
  behaviorScore        Float     @default(0)
  embeddingScore       Float     @default(0)
  totalScore           Float     @default(0)
  updatedAt            DateTime  @updatedAt

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([candidateId, totalScore(sort: Desc)])
}

model ReputationScore {
  id        String           @id @default(cuid())
  profileId String           @unique
  profile   CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  score     Int              @default(0)
  factors   Json
  updatedAt DateTime         @updatedAt
}

model AIExplainabilityLog {
  id              String           @id @default(cuid())
  profileId       String
  profile         CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  featureName     String
  inputHash       String?
  outputJson      Json
  executionTimeMs Int?
  createdAt       DateTime         @default(now())
}

// In-app notification hub — covers application events, interview reminders, offers, etc.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  isRead    Boolean          @default(false)
  metadata  Json?            // e.g. { jobId, applicationId, interviewId }
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
